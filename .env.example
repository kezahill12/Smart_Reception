########################################
# DATABASE CONFIGURATION
########################################

# Use "db" as host when running with Docker Compose
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/smartreception

# Database credentials
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=password

# Hibernate settings
SPRING_JPA_HIBERNATE_DDL_AUTO=update

########################################
# SPRING SECURITY CONFIGURATION
########################################

# Default login credentials (change in production!)
SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=password

#######################################
#  GOOGLE
#######################################
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret

########################################
# GITHUB
########################################
GITHUB_CLIENT_ID=your_github_id
GITHUB_CLIENT_SECRET=your_github_secret

#######################################
# JWT
########################################
JWT_SECRET=your_long_secret_key_here_at_least_32_chars
JWT_EXPIRATION=86400000

########################################
# APPLICATION CONFIGURATION
########################################

# App port (optional override)
SERVER_PORT=8080