########################################
# DATABASE CONFIGURATION
########################################

# Use "db" as host when running with Docker Compose
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/smartreception

# Database credentials
SPRING_DATASOURCE_USERNAME=your_db_username
SPRING_DATASOURCE_PASSWORD=your_db_password

# Hibernate settings
SPRING_JPA_HIBERNATE_DDL_AUTO=update


########################################
# SPRING SECURITY CONFIGURATION
########################################

# Default login credentials (change in production!)
SPRING_SECURITY_USER_NAME=admin
SPRING_SECURITY_USER_PASSWORD=your_secure_password


########################################
# APPLICATION CONFIGURATION
########################################

# App port (optional override)
SERVER_PORT=8080